---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://sitemaps.org">
  <!-- Dynamic Nunjucks Loop mapping all public static pages error-free -->
  {%- for page in collections.all %}
    {%- if not "/admin/" in page.url and not "/connect/" in page.url %}
    <url>
      <loc>https://seventhdaytheocraticworld.org{{ page.url }}</loc>
      <lastmod>2026-06-21</lastmod>
      <changefreq>weekly</changefreq>
      <priority>{% if page.url == "/" %}1.0{% else %}0.8{% endif %}</priority>
    </url>
    {%- endif %}
  {%- endfor %}
</urlset>
